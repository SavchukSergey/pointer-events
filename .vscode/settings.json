  },
  "[html]": {
    "files.eol": "\n",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
  },
  "[json]": {
    "files.eol": "\n",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
  },
  "[scss]": {
    "files.eol": "\n",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
  }
}